<Window x:Class="GeometryDash.Views.Level2Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GeometryDash.Views"
        mc:Ignorable="d"
        Title="Level2Window" Height="450" Width="1500">
    <Grid>
        <MediaElement Name="BackgroundMusic" Source="/Resources/Звук Dry Out.mp3" LoadedBehavior="Manual" UnloadedBehavior="Stop" />

        <Image Source="/Resources/logo12.jpg" Stretch="UniformToFill"/>
        <Canvas Name="GameCanvas" Margin="0,0,0,10" RenderTransformOrigin="0.823,0.561">
            <Image Name="PlayerSprite" Height="30" Canvas.Left="44" Canvas.Top="200" Width="30" Source="/Views/logo4.png" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Rectangle Name="Obstacle1" Fill="Aqua" Width="30" Height="30" Canvas.Left="331" Canvas.Top="200" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Polygon Name="Obstacle2" Fill="DeepPink" Points="0,30 15,0 30,30" Canvas.Left="789" Canvas.Top="200" />
            <Button Name="Menu" Width="60" Height="27" Background="Aquamarine" Canvas.Left="10" Click="Menu_Click" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Menu" />
            <Image Name="Logo" Source="/Views/logo7-Photoroom.png" Width="185" Height="41" HorizontalAlignment="Left" VerticalAlignment="Top" Canvas.Left="10" Canvas.Top="388"/>
            <Rectangle Name="PositiveObstacle1" Fill="DarkViolet" Width="57" Height="64" Canvas.Left="550" Canvas.Top="166" RenderTransformOrigin="0.523,0.538" HorizontalAlignment="Center" VerticalAlignment="Top"/>

            <Polygon Name="Obstacle4" Fill="Red" Points="0,30 15,0 30,30" Canvas.Left="1338" Canvas.Top="202" />

            <Rectangle Name="PositiveObstacle2" Fill="LightCoral" Width="95" Height="68" Canvas.Left="1019" Canvas.Top="162" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle Name="PositiveObstacle3" Fill="LightCoral" Width="94" Height="71" Canvas.Left="1604" Canvas.Top="162" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle Name="PositiveObstacle4" Fill="LightCoral" Width="95" Height="38" Canvas.Left="1722" Canvas.Top="125" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle Name="PositiveObstacle5" Fill="Violet" Width="88" Height="30" Canvas.Left="1870" Canvas.Top="200" HorizontalAlignment="Left" VerticalAlignment="Top"/>


        </Canvas>
    </Grid>
</Window>
