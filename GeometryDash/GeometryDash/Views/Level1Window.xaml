<Window x:Class="GeometryDash.Views.Level1Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GeometryDash.Views"
        mc:Ignorable="d"
        Title="Level1Window" Height="450" Width="1500">
    <Grid>
        <MediaElement Name="BackgroundMusic" Source="/Resources/Звук Dry Out.mp3" LoadedBehavior="Manual" UnloadedBehavior="Stop" />

        <Image Source="/Resources/logo13.jpg" Stretch="UniformToFill"/>
        <Canvas Name="GameCanvas" Margin="0,0,0,10" RenderTransformOrigin="0.823,0.561">
            <Image Name="PlayerSprite" Height="30" Canvas.Left="44" Canvas.Top="200" Width="30" Source="/Views/logo4.png" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Rectangle Name="Obstacle1" Fill="Aqua" Width="30" Height="30" Canvas.Left="400" Canvas.Top="200"/>
            <Polygon Name="Obstacle2" Fill="DeepPink" Points="0,30 15,0 30,30" Canvas.Left="600" Canvas.Top="200" />
            <Button Name="Menu" Width="60" Height="27" Background="Aquamarine" Canvas.Left="10" Click="Menu_Click" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Menu" />
            <Image Name="Logo" Source="/Views/logo7-Photoroom.png" Width="185" Height="41" HorizontalAlignment="Left" VerticalAlignment="Top" Canvas.Left="10" Canvas.Top="388"/>
            <Rectangle Name="PositiveObstacle1" Fill="DarkViolet" Width="57" Height="58" Canvas.Left="821" Canvas.Top="168" RenderTransformOrigin="1.483,0.768" HorizontalAlignment="Center" VerticalAlignment="Top"/>

            <Polygon Name="Obstacle4" Fill="Red" Points="0,30 15,0 30,30" Canvas.Left="1110" Canvas.Top="200" HorizontalAlignment="Left" VerticalAlignment="Center"/>

            <Rectangle Name="PositiveObstacle2" Fill="LightCoral" Width="95" Height="50" Canvas.Left="1301" Canvas.Top="180" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle Name="PositiveObstacle3" Fill="LightCoral" Width="94" Height="102" Canvas.Left="1453" Canvas.Top="128" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle Name="PositiveObstacle4" Fill="LightCoral" Width="95" Height="159" Canvas.Left="1591" Canvas.Top="71" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle Name="PositiveObstacle5" Fill="Violet" Width="88" Height="159" Canvas.Left="1775" Canvas.Top="71" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        </Canvas>
    </Grid>
</Window>
