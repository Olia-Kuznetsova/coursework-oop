<Window x:Class="GeometryDash.Views.GameOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Options" Height="450" Width="800">
    <Grid Margin="1,0,-1,0">
        <Image Source="pack://application:,,,/Resources/logo1.jpg" Stretch="UniformToFill"/>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border CornerRadius="5" BorderThickness="2" BorderBrush="Black" Margin="0,0,0,5">
                <Button Content="Return to Menu" Margin="2" Width="150" Height="50" Background="Aqua" FontSize="16" FontWeight="Bold" Click="ReturnToMenu_Click"/>
            </Border>
            <Border CornerRadius="5" BorderThickness="2" BorderBrush="Black" Margin="0,0,0,5">
                <Button Content="Continue" Margin="2" Width="150" Height="50" Background="LightYellow" FontWeight="Bold" FontSize="16" Click="ContinueGame_Click"/>
            </Border>
            <Border CornerRadius="5" BorderThickness="2" BorderBrush="Black" Margin="0,0,0,5">
                <Button Content="Exit Game" Margin="2" Width="150" Height="50" Background="Red" FontSize="16" FontWeight="Bold" Click="ExitGame_Click"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>
