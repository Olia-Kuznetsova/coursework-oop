<Window x:Class="GeometryDash.Views.MainMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Geometry Dash" Height="618" Width="1229">
    <Grid>
        <Image Source="pack://application:,,,/Resources/logo.jpg" Stretch="UniformToFill"/>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border CornerRadius="5" BorderThickness="2" BorderBrush="Black" >
                <Button Content="Play Level 1" Margin="2" Width="150" Height="50" Background="LimeGreen" FontSize="16" FontWeight="Bold" Click="PlayLevel1Button_Click"/>
            </Border>
            <Border CornerRadius="5" BorderThickness="2" BorderBrush="Black">
                <Button Content="Play Level 2" Margin="2" Width="150" Height="50" Background="LimeGreen" FontSize="16" FontWeight="Bold" Click="PlayLevel2Button_Click"/>
            </Border>
            <Border CornerRadius="5" BorderThickness="2" BorderBrush="Black">
                <Button Content="Play Level 3" Margin="2" Width="150" Height="50" Background="LimeGreen" FontSize="16" FontWeight="Bold" Click="PlayLevel3Button_Click"/>
            </Border>
          
            <Border CornerRadius="5" BorderThickness="2" BorderBrush="Black">
                <Button Content="Exit" Margin="2" Width="150" Height="50" Background="Red" FontSize="16" FontWeight="Bold" Click="ExitButton_Click"/>
            </Border>
        </StackPanel>
    </Grid>
</Window>
