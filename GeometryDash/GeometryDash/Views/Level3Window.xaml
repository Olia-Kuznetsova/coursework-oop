<Window x:Class="GeometryDash.Views.Level3Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GeometryDash.Views"
        mc:Ignorable="d"
        Title="Level3Window" Height="450" Width="2000">
    <Grid>
        <MediaElement Name="BackgroundMusic" Source="/Resources/Звук Dry Out.mp3" LoadedBehavior="Manual" UnloadedBehavior="Stop" />

        <Image Source="/Resources/logo17.jpg" Stretch="UniformToFill" Margin="0,0,-2109,0"/>
        <Canvas Name="GameCanvas" Margin="0,0,0,10" RenderTransformOrigin="0.823,0.561">
            <Image Name="PlayerSprite" Height="30" Canvas.Left="44" Canvas.Top="200" Width="30" Source="/Views/logo4.png" HorizontalAlignment="Left" VerticalAlignment="Top"/>

            <Polygon Name="Obstacle1" Fill="Aqua" Points="0,30 15,0 30,30" Canvas.Left="683" Canvas.Top="200" />
            <Polygon Name="Obstacle2" Fill="DeepPink" Points="0,30 15,0 30,30" Canvas.Left="350" Canvas.Top="200" />

            <Button Name="Menu" Width="60" Height="27" Background="Aquamarine" Canvas.Left="10" Click="Menu_Click" HorizontalAlignment="Left" VerticalAlignment="Top" Content="Menu" />
            <Image Name="Logo" Source="/Views/logo7-Photoroom.png" Width="185" Height="41" HorizontalAlignment="Center" VerticalAlignment="Top" Canvas.Left="10" Canvas.Top="378"/>
            <Rectangle Name="PositiveObstacle1" Fill="DarkViolet" Width="57" Height="132" Canvas.Left="1579" Canvas.Top="95" RenderTransformOrigin="1.483,0.768" HorizontalAlignment="Center" VerticalAlignment="Center"/>


            <Rectangle Name="PositiveObstacle2" Fill="LightCoral" Width="96" Height="80" Canvas.Left="1042" Canvas.Top="150" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle Name="PositiveObstacle3" Fill="LightCoral" Width="94" Height="132" Canvas.Left="1281" Canvas.Top="95" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Rectangle Name="PositiveObstacle5" Fill="Violet" Width="88" Height="75" Canvas.Left="1882" Canvas.Top="152" HorizontalAlignment="Center" VerticalAlignment="Top"/>


        </Canvas>
    </Grid>
</Window>